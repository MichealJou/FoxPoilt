{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@foxpilot/contracts/*": ["packages/contracts/src/*"],
      "@foxpilot/runtime/*": ["packages/runtime/src/*"],
      "@foxpilot/infra/*": ["packages/infra/src/*"],
      "@foxpilot/integrations/*": ["packages/integrations/src/*"],
      "@desktop/*": ["apps/desktop/src/*"],
      "@tests/*": ["tests/*"]
    },
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "apps/desktop/src/**/*.ts",
    "apps/desktop/src/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "vitest.config.ts"
  ]
}
