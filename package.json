{
  "name": "foxpilot",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "foxpilot": "dist/cli/run.js",
    "fp": "dist/cli/run.js"
  },
  "files": [
    "dist",
    "examples",
    "scripts",
    "README.md",
    "README.zh-CN.md",
    "README.en.md",
    "README.ja.md",
    "docs/specs",
    "docs/workspace"
  ],
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "postinstall": "node scripts/postinstall.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build",
    "cli": "tsx src/cli/run.ts",
    "verify:install": "zsh ./scripts/verify-install.sh",
    "release:assets": "sh ./scripts/build-release-assets.sh",
    "brew:formula": "node ./scripts/render-homebrew-formula.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.30",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
