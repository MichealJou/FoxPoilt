{
  "name": "foxpilot-workspace",
  "version": "0.1.4",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "type": "module",
  "scripts": {
    "build": "pnpm turbo run build --filter=foxpilot && pnpm turbo run build --filter=foxpilot-desktop",
    "build:all": "pnpm turbo run build",
    "clean": "pnpm turbo run clean && rm -rf dist dist-ui install-manifest.json",
    "lint": "pnpm exec oxlint . --ignore-path .gitignore --import-plugin --react-plugin --jsx-a11y-plugin --vitest-plugin --node-plugin --deny-warnings",
    "lint:fix": "pnpm exec oxlint . --ignore-path .gitignore --import-plugin --react-plugin --jsx-a11y-plugin --vitest-plugin --node-plugin --fix",
    "format": "pnpm exec prettier . --write",
    "format:check": "pnpm exec prettier . --check",
    "check:code": "pnpm lint && pnpm format:check",
    "check:all": "pnpm check:code && pnpm typecheck && pnpm test",
    "test": "vitest run",
    "test:ui": "vitest run tests/ui",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm --filter foxpilot typecheck && pnpm --filter foxpilot-desktop typecheck",
    "cli": "pnpm --filter foxpilot cli",
    "ui:dev": "pnpm --filter foxpilot-desktop ui:dev",
    "ui:build": "pnpm --filter foxpilot-desktop ui:build",
    "desktop:dev": "pnpm --filter foxpilot-desktop desktop:dev",
    "desktop:build": "pnpm --filter foxpilot-desktop desktop:build",
    "verify:install": "zsh ./scripts/verify-install.sh",
    "release:assets": "sh ./scripts/build-release-assets.sh",
    "release:publish": "sh ./scripts/publish-github-release.sh",
    "brew:formula": "node ./scripts/render-homebrew-formula.mjs",
    "brew:publish": "sh ./scripts/publish-homebrew-tap.sh"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "better-sqlite3": "catalog:",
    "jsdom": "catalog:",
    "oxlint": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
