{
  "name": "foxpilot-workspace",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter foxpilot build",
    "build:all": "pnpm turbo run build",
    "clean": "pnpm turbo run clean && rm -rf dist",
    "test": "vitest run",
    "test:ui": "vitest run tests/ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && pnpm --filter foxpilot-desktop typecheck",
    "cli": "pnpm --filter foxpilot cli",
    "ui:dev": "pnpm --filter foxpilot-desktop ui:dev",
    "ui:build": "pnpm --filter foxpilot-desktop ui:build",
    "desktop:dev": "pnpm --filter foxpilot-desktop desktop:dev",
    "desktop:build": "pnpm --filter foxpilot-desktop desktop:build",
    "verify:install": "zsh ./scripts/verify-install.sh",
    "release:assets": "sh ./scripts/build-release-assets.sh",
    "release:publish": "sh ./scripts/publish-github-release.sh",
    "brew:formula": "node ./scripts/render-homebrew-formula.mjs",
    "brew:publish": "sh ./scripts/publish-homebrew-tap.sh"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@tauri-apps/api": "^2.10.1",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.5.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^8.0.3",
    "vitest": "^3.2.4"
  }
}
