{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "../../src/*"
      ],
      "@foxpilot/contracts/*": [
        "../../packages/contracts/src/*"
      ],
      "@foxpilot/runtime/*": [
        "../../packages/runtime/src/*"
      ],
      "@foxpilot/infra/*": [
        "../../packages/infra/src/*"
      ],
      "@foxpilot/integrations/*": [
        "../../packages/integrations/src/*"
      ],
      "@desktop/*": [
        "./src/*"
      ],
      "@tests/*": [
        "../../tests/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx"
  ]
}
