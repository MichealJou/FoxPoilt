{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "../../src/*"
      ],
      "@contracts/*": [
        "../../packages/contracts/src/*"
      ],
      "@runtime/*": [
        "../../packages/runtime/src/*"
      ],
      "@control-plane/*": [
        "../../packages/runtime/src/read-models/*"
      ],
      "@infra/*": [
        "../../packages/infra/src/*"
      ],
      "@integrations/*": [
        "../../packages/integrations/src/*"
      ],
      "@desktop/*": [
        "./src/*"
      ],
      "@tests/*": [
        "../../tests/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx"
  ]
}
