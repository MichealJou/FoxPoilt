{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@contracts/*": [
        "packages/contracts/src/*"
      ],
      "@runtime/*": [
        "packages/runtime/src/*"
      ],
      "@control-plane/*": [
        "packages/runtime/src/read-models/*"
      ],
      "@infra/*": [
        "packages/infra/src/*"
      ],
      "@integrations/*": [
        "packages/integrations/src/*"
      ],
      "@tests/*": [
        "tests/*"
      ],
      "@desktop/*": [
        "apps/desktop/src/*"
      ]
    },
    "outDir": "./dist",
    "types": [
      "node"
    ],
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "../../src/**/*.ts",
    "../../src/**/*.tsx",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx"
  ],
  "exclude": [
    "../../tests/**/*.ts",
    "../../tests/**/*.tsx"
  ]
}
