{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "paths": {
      "@/*": ["apps/cli/src/*"],
      "@foxpilot/contracts/*": ["packages/contracts/src/*"],
      "@foxpilot/runtime/*": ["packages/runtime/src/*"],
      "@foxpilot/infra/*": ["packages/infra/src/*"],
      "@foxpilot/integrations/*": ["packages/integrations/src/*"],
      "@tests/*": ["tests/*"],
      "@desktop/*": ["apps/desktop/src/*"]
    },
    "outDir": "./dist",
    "rootDir": "../..",
    "types": ["node"],
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx"
  ],
  "exclude": ["../../tests/**/*.ts", "../../tests/**/*.tsx"]
}
